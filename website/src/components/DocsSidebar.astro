---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}docs/`, label: 'Getting Started' },
  { href: `${base}docs/architecture/`, label: 'Architecture' },
  { href: `${base}docs/cli/`, label: 'CLI Reference' },
  { href: `${base}docs/conformance/`, label: 'Conformance' },
  { href: `${base}docs/limitations/`, label: 'Limitations' },
];
---
<aside class="docs-sidebar">
  <nav>
    <h3>Documentation</h3>
    <ul>
      {links.map(link => (
        <li>
          <a href={link.href} class:list={[{ active: currentPath.endsWith(link.href.replace(base, '/')) || currentPath === link.href }]}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .docs-sidebar {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--header-height) + 1rem);
    align-self: flex-start;
  }

  h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    margin-bottom: 0.75rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li { margin: 0; }

  a {
    display: block;
    padding: 0.375rem 0.75rem;
    color: var(--fg-muted);
    font-size: 0.875rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  a:hover {
    color: var(--fg);
    background: var(--bg-secondary);
    text-decoration: none;
  }

  a.active {
    color: var(--accent);
    background: var(--accent-light);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .docs-sidebar {
      width: 100%;
      position: static;
    }

    ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }
  }
</style>
