---
import CodeBlock from './CodeBlock.astro';
const base = import.meta.env.BASE_URL;
---
<section class="hero">
  <div class="container">
    <h1 class="hero-title">TypeScript, compiled.</h1>
    <p class="hero-subtitle">
      An LLVM-based ahead-of-time compiler that turns TypeScript into standalone
      native executables. No Node.js required.
    </p>
    <p class="hero-byline">Built entirely by <a href="https://claude.ai" target="_blank" rel="noopener">Claude</a>, Anthropic's AI.</p>
    <div class="hero-code">
      <CodeBlock code="ts-aot app.ts -o app && ./app" lang="bash" />
    </div>
    <div class="hero-ctas">
      <a href={`${base}docs/`} class="btn btn-primary">Get Started</a>
      <a href="https://github.com/OffByOneStudios/ts-aot" class="btn btn-secondary" target="_blank" rel="noopener">
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 3rem;
    text-align: center;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 560px;
    margin: 1rem auto 0;
    line-height: 1.6;
  }

  .hero-code {
    max-width: 460px;
    margin: 2rem auto 0;
    text-align: left;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .hero-byline {
    font-size: 0.9375rem;
    color: var(--fg-muted);
    margin-top: 0.5rem;
  }

  .hero-byline a {
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .hero { padding: 3rem 0 2rem; }
    .hero-title { font-size: 2.25rem; }
    .hero-subtitle { font-size: 1.0625rem; }
    .hero-ctas { flex-direction: column; align-items: center; }
  }
</style>
