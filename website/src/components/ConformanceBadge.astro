---
interface Props {
  label: string;
  percentage: number;
  detail: string;
  href?: string;
}

const { label, percentage, detail, href } = Astro.props;
const circumference = 2 * Math.PI * 40;
const offset = circumference - (percentage / 100) * circumference;
---
<a href={href} class="badge-link">
  <div class="badge">
    <svg class="badge-ring" viewBox="0 0 100 100" width="100" height="100">
      <circle class="ring-bg" cx="50" cy="50" r="40" />
      <circle
        class="ring-fill"
        cx="50" cy="50" r="40"
        style={`stroke-dasharray: ${circumference}; stroke-dashoffset: ${offset};`}
      />
    </svg>
    <div class="badge-pct">{percentage}%</div>
    <div class="badge-label">{label}</div>
    <div class="badge-detail">{detail}</div>
  </div>
</a>

<style>
  .badge-link {
    text-decoration: none;
    color: inherit;
  }

  .badge-link:hover { text-decoration: none; }
  .badge-link:hover .badge { border-color: var(--accent); }

  .badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.15s;
    background: var(--bg);
  }

  .badge-ring { margin-bottom: 0.75rem; }

  .ring-bg {
    fill: none;
    stroke: var(--border-light);
    stroke-width: 6;
  }

  .ring-fill {
    fill: none;
    stroke: var(--accent);
    stroke-width: 6;
    stroke-linecap: round;
    transform: rotate(-90deg);
    transform-origin: center;
    transition: stroke-dashoffset 0.6s ease;
  }

  .badge-pct {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: -0.25rem;
  }

  .badge-label {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-top: 0.25rem;
  }

  .badge-detail {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    margin-top: 0.125rem;
  }
</style>
