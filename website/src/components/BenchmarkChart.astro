---
interface Bar {
  label: string;
  value: number;
  unit: string;
  highlight?: boolean;
}

interface Props {
  title: string;
  bars: Bar[];
  note?: string;
}

const { title, bars, note } = Astro.props;
const maxValue = Math.max(...bars.map(b => b.value));
---
<div class="benchmark">
  <h4>{title}</h4>
  <div class="bars">
    {bars.map(bar => (
      <div class="bar-row">
        <span class="bar-label">{bar.label}</span>
        <div class="bar-track">
          <div
            class:list={['bar-fill', { highlight: bar.highlight }]}
            style={`width: ${(bar.value / maxValue) * 100}%`}
          >
            <span class="bar-value">{bar.value}{bar.unit}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
  {note && <p class="bench-note">{note}</p>}
</div>

<style>
  .benchmark {
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
  }

  h4 {
    font-size: 0.9375rem;
    margin: 0 0 1rem;
  }

  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bar-label {
    width: 70px;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    text-align: right;
    flex-shrink: 0;
  }

  .bar-track {
    flex: 1;
    background: var(--bg-secondary);
    border-radius: 4px;
    height: 28px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    padding: 0 0.5rem;
    min-width: fit-content;
    transition: width 0.4s ease;
  }

  .bar-fill.highlight {
    background: var(--accent);
  }

  .bar-value {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
  }

  .bar-fill.highlight .bar-value {
    color: #fff;
  }

  .bench-note {
    font-size: 0.8125rem;
    color: var(--fg-muted);
    margin-top: 0.75rem;
    font-style: italic;
  }
</style>
