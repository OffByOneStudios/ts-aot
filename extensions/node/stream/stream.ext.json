          "call": "ts_stream_resume",
          "hirName": "ts_Readable_resume",
          "params": [],
          "returns": "Readable",
          "lowering": { "args": ["ptr"], "returns": "void" }
        },
        "pause": {
          "call": "ts_stream_pause",
          "hirName": "ts_Readable_pause",
          "params": [],
          "returns": "Readable",
          "lowering": { "args": ["ptr"], "returns": "void" }
