          "params": [
            { "name": "encoding", "type": "string" }
          ],
          "returns": "Readable",
          "lowering": { "args": ["ptr", "ptr"], "returns": "ptr" }
        },
        "wrap": {
          "call": "ts_readable_wrap",
          "hirName": "ts_Readable_wrap",
          "params": [
            { "name": "oldStream", "type": "any" }
          ],
          "returns": "Readable",
          "lowering": { "args": ["ptr", "ptr"], "returns": "ptr" }
        }
      },
      "staticMethods": {
