          "call": "ts_readable_from",
          "hirName": "ts_Readable_from",
          "params": [
            { "name": "iterable", "type": "any" }
          ],
          "returns": "Readable",
          "lowering": { "args": ["ptr"], "returns": "ptr" }
        }
