        "pending": { "type": "boolean", "getter": "ts_read_stream_pending", "lowering": { "args": ["ptr"], "returns": "i1" } }
      }
    },
    "WriteStream": {
      "kind": "class",
      "extends": "Writable",
      "properties": {
        "bytesWritten": { "type": "number", "getter": "ts_write_stream_bytes_written", "lowering": { "args": ["ptr"], "returns": "i64" } },
        "path": { "type": "string", "getter": "ts_write_stream_path", "lowering": { "args": ["ptr"], "returns": "ptr" } },
        "pending": { "type": "boolean", "getter": "ts_write_stream_pending", "lowering": { "args": ["ptr"], "returns": "i1" } }
