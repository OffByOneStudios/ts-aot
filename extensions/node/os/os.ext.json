{
  "name": "os",
  "version": "1.0.0",
  "module": "os",
  "description": "Node.js os module - operating system information",
  "methods": {
    "platform": {
      "native": "ts_os_platform",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "arch": {
      "native": "ts_os_arch",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "type": {
      "native": "ts_os_type",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "release": {
      "native": "ts_os_release",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "version": {
      "native": "ts_os_version",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "hostname": {
      "native": "ts_os_hostname",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "machine": {
      "native": "ts_os_machine",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "homedir": {
      "native": "ts_os_homedir",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "tmpdir": {
      "native": "ts_os_tmpdir",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "totalmem": {
      "native": "ts_os_totalmem",
      "args": [],
      "returns": { "type": "I64" }
    },
    "freemem": {
      "native": "ts_os_freemem",
      "args": [],
      "returns": { "type": "I64" }
    },
    "availableParallelism": {
      "native": "ts_os_availableParallelism",
      "args": [],
      "returns": { "type": "I64" }
    },
    "uptime": {
      "native": "ts_os_uptime",
      "args": [],
      "returns": { "type": "F64" }
    },
    "loadavg": {
      "native": "ts_os_loadavg",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "cpus": {
      "native": "ts_os_cpus",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "endianness": {
      "native": "ts_os_endianness",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "networkInterfaces": {
      "native": "ts_os_networkInterfaces",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "userInfo": {
      "native": "ts_os_userInfo",
      "args": [],
      "returns": { "type": "Ptr" }
    },
    "getPriority": {
      "native": "ts_os_getPriority",
      "args": [{ "name": "pid", "type": "I64" }],
      "returns": { "type": "I64" }
    },
    "setPriority": {
      "native": "ts_os_setPriority",
      "args": [
        { "name": "pid", "type": "I64" },
        { "name": "priority", "type": "I64" }
      ],
      "returns": { "type": "Void" }
    }
  },
  "properties": {
    "EOL": {
      "native": "ts_os_get_eol",
      "type": "Ptr"
    },
    "devNull": {
      "native": "ts_os_get_devnull",
      "type": "Ptr"
    },
    "constants": {
      "native": "ts_os_get_constants",
      "type": "Ptr"
    }
  }
}
